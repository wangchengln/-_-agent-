# Embedding via Alibaba Bailian (DashScope) OpenAI-compatible mode
OPENAI_API_KEY=sk-xxx
# 中国(北京)区用下面这个；海外区改为 https://dashscope-intl.aliyuncs.com/compatible-mode/v1
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MODEL_NAME=gpt-4o-mini

DEEPSEEK_API_KEY=xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Embedding model: text-embedding-v4(北京区) / text-embedding-v3(海外区)
EMBEDDING_MODEL=text-embedding-v4

# Tavily Web Search
TAVILY_API_KEY=your_tavily_api_key_here

# Server
HOST=0.0.0.0
PORT=8002
# Set to 1 to skip background memory-index warm-up on startup (RAG still lazy-loads on first use)
# SKIP_MEMORY_INDEX_ON_STARTUP=0
 
# OpenWeather API Configuration 
OPENWEATHER_API_KEY=your_openweather_api_key_here 

# Amap (高德) — Web 服务 Key（POI 搜索 / 天气 / 路径规划；仅后端 REST）
AMAP_WEB_SERVICE_KEY=your_amap_web_service_key_here
# 旧变量名仍兼容，二选一即可：
# AMAP_API_KEY=your_amap_web_service_key_here

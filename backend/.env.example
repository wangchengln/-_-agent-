# Embedding via Alibaba Bailian (DashScope) OpenAI-compatible mode
OPENAI_API_KEY=sk-xxx
# 中国(北京)区用下面这个；海外区改为 https://dashscope-intl.aliyuncs.com/compatible-mode/v1
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MODEL_NAME=gpt-4o-mini

DEEPSEEK_API_KEY=xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Embedding model: text-embedding-v4(北京区) / text-embedding-v3(海外区)
EMBEDDING_MODEL=text-embedding-v4

# Tavily Web Search
TAVILY_API_KEY=your_tavily_api_key_here

# Server
HOST=0.0.0.0
PORT=8002
 
# OpenWeather API Configuration 
OPENWEATHER_API_KEY=your_openweather_api_key_here 

# Amap (高德) Web Service
AMAP_API_KEY=your_amap_web_service_key_here
